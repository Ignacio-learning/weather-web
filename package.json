{
  "name": "chile-data-hub",
  "version": "2.0.0",
  "description": "Portal de datos chilenos: clima, indicadores económicos, sismos, feriados y más.",
  "private": true,
  "scripts": {
    "dev": "concurrently -n server,client -c cyan,magenta \"cd server && tsx watch src/index.ts\" \"cd client && vite\"",
    "build": "npm run build:client && npm run build:server",
    "build:client": "cd client && tsc -b && vite build",
    "build:server": "cd server && tsup src/index.ts --out-dir dist",
    "start": "node server/dist/index.cjs",
    "lint": "cd client && oxlint",
    "preview": "cd client && vite preview"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^6.30.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.1.0",
    "oxlint": "^1.71.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^6.0.2",
    "vite": "^8.1.1"
  },
  "author": "",
  "license": "MIT"
}
